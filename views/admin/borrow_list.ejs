<link rel="stylesheet" href="/css/admin-borrow-list.css">

<div class="top-bar">
  <h1>รายการขอยืมอุปกรณ์</h1>
  <div class="top-right">
    <div class="search">
      <input type="text" class="admin-search"
        data-target=".borrow_list-row"
        placeholder="ค้นหาอุปกรณ์ / ผู้ยืม">
      <i class="fa-solid fa-magnifying-glass"></i>
    </div>
    <div class="admin-box">
      <span>Admin</span>
      <i class="fa-solid fa-user"></i>
    </div>
    <div class="noti-wrap" id="notiWrap">
      <button class="noti-btn" id="notiBtn" aria-label="แจ้งเตือน">
        <i class="fa-solid fa-bell"></i>
        <span class="noti-badge" id="notiBadge" style="display:none;">0</span>
      </button>
      <div class="noti-dropdown" id="notiDropdown">
        <div class="noti-header">
          <span>การแจ้งเตือน</span>
          <span class="noti-count-label" id="notiCountLabel"></span>
        </div>
        <div class="noti-list" id="notiList">
          <div class="noti-empty">
            <i class="fa-solid fa-bell-slash"></i>
            <p>ไม่มีการแจ้งเตือน</p>
          </div>
        </div>
      </div>
    </div>
    <div class="logo-box"><img src="/images/logo.png"></div>
  </div>
</div>

<!-- SUMMARY -->
<div class="borrow-summary">
  <div class="bs-item">
    <div class="bs-icon all"><i class="fa-solid fa-list"></i></div>
    <div>
      <div class="bs-num"><%= borrows.length %></div>
      <div class="bs-label">ทั้งหมด</div>
    </div>
  </div>
  <div class="bs-item">
    <div class="bs-icon wait"><i class="fa-solid fa-clock"></i></div>
    <div>
      <div class="bs-num"><%= borrows.filter(b => b.BorrowStatusID == 1).length %></div>
      <div class="bs-label">รออนุมัติ</div>
    </div>
  </div>
  <div class="bs-item">
    <div class="bs-icon active"><i class="fa-solid fa-laptop"></i></div>
    <div>
      <div class="bs-num"><%= borrows.filter(b => b.BorrowStatusID == 6).length %></div>
      <div class="bs-label">กำลังยืม</div>
    </div>
  </div>
  <div class="bs-item">
    <div class="bs-icon done"><i class="fa-solid fa-circle-check"></i></div>
    <div>
      <div class="bs-num"><%= borrows.filter(b => b.BorrowStatusID == 4).length %></div>
      <div class="bs-label">คืนแล้ว</div>
    </div>
  </div>
  <div class="bs-item">
    <div class="bs-icon over"><i class="fa-solid fa-triangle-exclamation"></i></div>
    <div>
      <div class="bs-num"><%= borrows.filter(b => b.statusClass && b.statusClass.includes('red')).length %></div>
      <div class="bs-label">เกินกำหนด</div>
    </div>
  </div>
</div>

<!-- TABS -->
<div class="borrow-tabs">
  <a href="/admin/borrow?status=all" class="tab <%= status === 'all' ? 'active' : '' %>">
    <i class="fa-solid fa-list"></i> ทั้งหมด
  </a>
  <a href="/admin/borrow?status=1" class="tab <%= status == '1' ? 'active' : '' %>">
    <i class="fa-solid fa-clock"></i> รออนุมัติ
  </a>
  <a href="/admin/borrow?status=2" class="tab <%= status == '2' ? 'active' : '' %>">
    <i class="fa-solid fa-circle-check"></i> อนุมัติแล้ว
  </a>
  <a href="/admin/borrow?status=6" class="tab <%= status == '6' ? 'active' : '' %>">
    <i class="fa-solid fa-laptop"></i> กำลังยืม
  </a>
  <a href="/admin/borrow?status=3" class="tab <%= status == '3' ? 'active' : '' %>">
    <i class="fa-solid fa-xmark"></i> ปฏิเสธ
  </a>
  <a href="/admin/borrow?status=4" class="tab <%= status == '4' ? 'active' : '' %>">
    <i class="fa-solid fa-rotate-left"></i> คืนแล้ว
  </a>
  <a href="/admin/borrow?status=5" class="tab <%= status == '5' ? 'active' : '' %>">
    <i class="fa-solid fa-ban"></i> ยกเลิก
  </a>
</div>

<!-- TABLE -->
<div class="borrow-table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>#</th>
        <th>รูปภาพ</th>
        <th>อุปกรณ์</th>
        <th>เลขเอกสาร</th>
        <th>ผู้ยืม</th>
        <th>วันยืม</th>
        <th>กำหนดคืน</th>
        <th>สถานะ</th>
        <th>ดำเนินการโดย</th>
        <th>แจ้งซ่อม</th>
        <th>จัดการ</th>
        <th></th>
      </tr>
    </thead>
    <tbody>

    <% if (borrows.length === 0) { %>
      <tr>
        <td colspan="12" class="empty-row">
          <i class="fa-solid fa-inbox"></i>
          <p>ไม่พบรายการยืม</p>
        </td>
      </tr>
    <% } %>

    <% borrows.forEach((b, index) => { %>
    <tr class="borrow_list-row" data-status="<%= b.BorrowStatusID %>">

      <td class="col-no"><%= index + 1 %></td>

      <!-- อุปกรณ์ -->
      <td class="td-img">
        <div class="device-thumb">
          <% if (b.DeviceImage) { %>
            <img src="/uploads/device/<%= b.DeviceImage %>"
                onerror="this.src='/images/no-image.png'">
          <% } else if (b.TypeImage) { %>
            <img src="/uploads/type/<%= b.TypeImage %>"
                onerror="this.src='/images/no-image.png'">
          <% } else { %>
            <img src="/images/no-image.png">
          <% } %>
        </div>
      </td>

      <td>
        <% if (b.DVID) { %>
          <div class="device-name"><%= b.DeviceName %></div>
          <div class="device-meta"><%= b.ITCode || '-' %></div>
        <% } else { %>
          <div class="device-name pending-device">
            <i class="fa-solid fa-hourglass-half"></i> ยังไม่เลือกเครื่อง
          </div>
          <div class="device-meta"><%= b.TypeName || '-' %></div>
        <% } %>
      </td>

      <!-- เลขเอกสาร -->
      <td>
        <span class="borrow-code"><%= b.BorrowCode %></span>
      </td>

      <!-- ผู้ยืม -->
      <td>
        <div class="person-name"><%= b.fname %> <%= b.lname %></div>
      </td>

      <!-- วันที่ -->
      <td class="date-col"><%= b.BorrowDate %></td>
      <td class="date-col"><%= b.DueDate %></td>

      <!-- สถานะ -->
      <td>
        <% if (b.BorrowStatusID == 1) { %>
          <span class="badge gray">รออนุมัติ</span>
        <% } else if (b.BorrowStatusID == 3) { %>
          <span class="badge red">ปฏิเสธ</span>
        <% } else if (b.BorrowStatusID == 4) { %>
          <span class="badge green">คืนแล้ว</span>
        <% } else if (b.BorrowStatusID == 5) { %>
          <span class="badge orange">ยกเลิก</span>
        <% } %>
        <% if (b.statusText) { %>
          <span class="<%= b.statusClass %>"><%= b.statusText %></span>
        <% } %>
      </td>

      <!-- ดำเนินการโดย -->
      <td>
        <% if (b.ActionBy) { %>
          <div class="action-by">
            <i class="fa-solid fa-user-check"></i>
            <%= b.ActionBy %>
          </div>
        <% } else { %>
          <span class="no-data">—</span>
        <% } %>
      </td>

      <!-- จัดการ -->
      <td>
        <div class="action-box">

          <% if (b.BorrowStatusID == 1) { %>
            <button type="button" class="btn green btn-approve"
              data-id="<%= b.BorrowID %>"
              data-type="<%= b.TypeID %>">
              <i class="fa-solid fa-check"></i> อนุมัติ
            </button>
            <button type="button" class="btn red btn-reject"
              data-id="<%= b.BorrowID %>">
              <i class="fa-solid fa-xmark"></i> ไม่อนุมัติ
            </button>
          <% } %>

          <% if (b.BorrowStatusID == 6) { %>
            <form action="/admin/borrow/return/<%= b.BorrowID %>" method="POST">
              <button type="submit" class="btn blue">
                <i class="fa-solid fa-rotate-left"></i> คืนอุปกรณ์
              </button>
            </form>
          <% } %>

          <% if (b.BorrowStatusID == 3 || b.BorrowStatusID == 4) { %>
            <% if (b.RepairID) { %>
              <button class="icon-action gray" disabled title="อยู่ระหว่างซ่อม">
                <i class="fa-solid fa-screwdriver-wrench"></i>
              </button>
            <% } else if (b.IsBorrowing) { %>
              <button class="icon-action gray" disabled title="อุปกรณ์ยังมีการยืมอยู่">
                <i class="fa-solid fa-screwdriver-wrench"></i>
              </button>
            <% } else { %>
              <button type="button" class="icon-action warning btn-repair"
                data-dvid="<%= b.DVID %>" title="ส่งซ่อม">
                <i class="fa-solid fa-screwdriver-wrench"></i>
              </button>
            <% } %>
          <% } %>

        </div>
      </td>

      <!-- ดูรายละเอียด -->
      <td>
        <div class="action-box">
          <button class="btn-detail" data-code="<%= b.BorrowCode %>" title="ดูรายละเอียด">
            <i class="fa-solid fa-eye"></i>
          </button>
          <button class="icon-action user" data-user-id="<%= b.EMPID %>" title="ข้อมูลผู้ยืม">
            <i class="fa-solid fa-user"></i>
          </button>
        </div>
      </td>

    </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<!-- DETAIL OVERLAY -->
<div id="detailOverlay" class="detail-overlay">
  <div class="detail-box">
    <button id="closeDetail" class="close-btn">
      <i class="fa-solid fa-xmark"></i>
    </button>
    <div id="detailContent"></div>
  </div>
</div>

<!-- REJECT MODAL -->
<div id="rejectModal" class="modal-overlay" style="display:none;">
  <div class="modal-box reject-modal">
    <h3>ปฏิเสธการยืม</h3>
    <form id="rejectForm" method="POST">
      <label class="modal-label">เหตุผลที่พบบ่อย</label>
      <select id="rejectReasonSelect" class="modal-select">
        <option value="">— เลือกเหตุผล —</option>
        <option value="อุปกรณ์ไม่พร้อมใช้งาน">อุปกรณ์ไม่พร้อมใช้งาน</option>
        <option value="ช่วงเวลายืมซ้ำกับผู้อื่น">ช่วงเวลายืมซ้ำกับผู้อื่น</option>
        <option value="ข้อมูลการยืมไม่ครบถ้วน">ข้อมูลการยืมไม่ครบถ้วน</option>
        <option value="ไม่ผ่านการอนุมัติจากหน่วยงาน">ไม่ผ่านการอนุมัติจากหน่วยงาน</option>
        <option value="อื่น ๆ">อื่น ๆ (พิมพ์เอง)</option>
      </select>
      <label class="modal-label">รายละเอียดเหตุผล</label>
      <textarea name="remark" id="rejectRemark" required
        placeholder="สามารถพิมพ์เหตุผลเพิ่มเติมได้"></textarea>
      <div class="modal-actions">
        <button type="button" id="closeReject" class="btn gray">ยกเลิก</button>
        <button type="submit" class="btn red">
          <i class="fa-solid fa-xmark"></i> ยืนยันปฏิเสธ
        </button>
      </div>
    </form>
  </div>
</div>

<!-- USER OVERLAY -->
<div id="userOverlay" class="detail-overlay">
  <div class="detail-box">
    <button id="closeUser" class="close-btn">
      <i class="fa-solid fa-xmark"></i>
    </button>
    <div id="userContent">
      <h3>ข้อมูลผู้ยืม</h3>
    </div>
  </div>
</div>

<!-- REPAIR MODAL -->
<div id="repairModal" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <h3><i class="fa-solid fa-screwdriver-wrench" style="color:#f97316"></i> แจ้งซ่อมอุปกรณ์</h3>
    <form id="repairForm" method="POST">
      <label class="modal-label">อาการเสีย</label>
      <textarea name="repair_remark" id="repairRemark" required
        placeholder="กรุณาระบุอาการเสีย เช่น เปิดไม่ติด / หน้าจอแตก"></textarea>
      <div class="modal-actions">
        <button type="button" id="closeRepair" class="btn gray">ยกเลิก</button>
        <button type="submit" class="btn orange">
          <i class="fa-solid fa-wrench"></i> ยืนยันส่งซ่อม
        </button>
      </div>
    </form>
  </div>
</div>

<!-- APPROVE MODAL -->
<div id="approveModal" class="modal-overlay" style="display:none;">
  <div class="modal-box">
    <h3><i class="fa-solid fa-check" style="color:#10b981"></i> เลือกอุปกรณ์ที่จะให้ยืม</h3>
    <form id="approveForm" method="POST">
      <input type="hidden" name="DVID" id="selectedDVID">
      <label class="modal-label">ค้นหาเครื่อง (IT Code / Asset Tag)</label>
      <input type="text" id="deviceSearch" class="modal-input"
        placeholder="พิมพ์เพื่อค้นหา..." autocomplete="off">
      <div id="deviceDropdown" class="device-dropdown" style="display:none;"></div>
      <div id="deviceInfo" class="device-selected-info" style="display:none;">
        <p><strong>เครื่องที่เลือก:</strong></p>
        <div id="deviceInfoContent"></div>
      </div>
      <div class="modal-actions">
        <button type="button" id="closeApprove" class="btn gray">ยกเลิก</button>
        <button type="submit" class="btn green" id="btnConfirmApprove" disabled>
          <i class="fa-solid fa-check"></i> ยืนยันอนุมัติ
        </button>
      </div>
    </form>
  </div>
</div>