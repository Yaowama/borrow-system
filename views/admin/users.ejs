        <h2>👥 จัดการผู้ใช้งาน (Admin)</h2>

        <table class="table">

            <thead>
                <tr>
                    <th>ชื่อ</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>สถานะ</th>
                    <th>จัดการ</th>
                </tr>
            </thead>

            <tbody>
            <% devices.forEach(d => { %>
                <tr>
                <td class="center">
                    <% if (d.DeviceImage) { %>
                    <img src="/uploads/device/<%= d.DeviceImage %>" class="device-img">
                    <% } else { %>
                    <span class="no-img">ไม่มีรูป</span>
                    <% } %>
                </td>

                <td><%= d.DeviceName %></td>
                <td><%= d.CategoryName || "-" %></td>
                <td><%= d.BrandName || "-" %></td>
                <td><%= d.ModelName || "-" %></td>

                <td class="center">
                    <% if (d.Stock > 1) { %>
                    <span class="stock green"><%= d.Stock %></span>
                    <% } else if (d.Stock == 1) { %>
                    <span class="stock yellow">1</span>
                    <% } else { %>
                    <span class="stock red">หมด</span>
                    <% } %>
                </td>

                <td>
                    <% if (d.Stock > 0) { %>
                    <a href="/user/borrow/<%= d.AnyDVID %>" class="btn blue">ยืม</a>
                    <% } else { %>
                    <span class="btn gray disabled">หมด</span>
                    <% } %>
                </td>
                </tr>
            <% }) %>
            </tbody>
        </table>

    </main>

</div>
