<link rel="stylesheet" href="/css/device_add.css">

<div class="top-bar">
  <h1>เพิ่มอุปกรณ์</h1>

  <div class="top-right">
    <div class="admin-box">
      <span>Admin</span>
      <i class="fa-solid fa-user"></i>
    </div>

    <div class="logo-box">
      <img src="/images/logo.png">
    </div>
  </div>
</div>

<div class="admin-card">

  <div class="card-header">
    <i class="fa-solid fa-box"></i>
    <span>ข้อมูลอุปกรณ์</span>
  </div>

<form
  method="POST"
  action="/admin/device/model/add"
  enctype="multipart/form-data"
>

<div class="form-grid">

  <div class="form-group full">
    <label>ชื่ออุปกรณ์</label>
    <input
      name="DeviceName"
      placeholder="เช่น โน้ตบุ๊ก / โปรเจคเตอร์ / แท็บเล็ต"
      required
    >
  </div>

  <div class="form-group full">
    <label>รุ่นอุปกรณ์</label>
    <input
      name="ModelName"
      placeholder="เช่น Dell Latitude 7420"
      required
    >
  </div>

  <div class="form-group">
    <label>หมวด</label>
    <select name="CategoryID" required>
      <option value="">เลือกหมวด</option>
      <% categories.forEach(c => { %>
        <option value="<%= c.CategoryID %>">
          <%= c.CategoryName %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label>ประเภท</label>
    <select name="TypeID" required>
      <option value="">เลือกประเภท</option>
      <% types.forEach(t => { %>
        <option value="<%= t.TypeID %>">
          <%= t.TypeName %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label>ยี่ห้อ</label>
    <select name="BrandID" required>
      <option value="">เลือกยี่ห้อ</option>
      <% brands.forEach(b => { %>
        <option value="<%= b.BrandID %>">
          <%= b.BrandName %>
        </option>
      <% }) %>
    </select>
  </div>


  <div class="form-group full">
    <label>รายละเอียด</label>
    <textarea name="Description"></textarea>
  </div>

  <div class="form-group upload-box full">
    <label>รูปอุปกรณ์</label>
    <input type="file" name="ModelImage" hidden id="img">
    <label for="img" class="upload-btn">
      📷 อัปโหลดรูป
    </label>
  </div>

</div>

<div class="form-actions">
  <a href="/admin/device" class="btn-cancel">ยกเลิก</a>
  <button class="btn-save">บันทึกรุ่น</button>
</div>

</form>
