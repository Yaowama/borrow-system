<link rel="stylesheet" href="/css/device-edit.css">

<div class="top-bar">
  <h1>แก้ไขอุปกรณ์</h1>

  <div class="top-right">
    <div class="admin-box">
      <span>Admin</span>
      <i class="fa-solid fa-user"></i>
    </div>

    <div class="noti-wrap" id="notiWrap">
      <button class="noti-btn" id="notiBtn" aria-label="แจ้งเตือน">
        <i class="fa-solid fa-bell"></i>
        <span class="noti-badge" id="notiBadge" style="display:none;">0</span>
      </button>

      <div class="noti-dropdown" id="notiDropdown">
        <div class="noti-header">
          <span>การแจ้งเตือน</span>
          <span class="noti-count-label" id="notiCountLabel"></span>
        </div>
        <div class="noti-list" id="notiList">
          <div class="noti-empty">
            <i class="fa-solid fa-bell-slash"></i>
            <p>ไม่มีการแจ้งเตือน</p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="logo-box">
      <img src="/images/logo.png">
    </div>
  </div>
</div>

<div class="admin-card">

<form method="POST"
      action="/admin/device/edit/<%= device.DeviceID %>"
      enctype="multipart/form-data">

<div class="form-grid">

  <div class="form-group full">
    <label>ชื่ออุปกรณ์</label>
    <input
      name="DeviceName"
      value="<%= device.DeviceName %>"
      required
    >
  </div>

  <div class="form-group">
  <label>ยี่ห้อ</label>
  <select name="BrandID" id="brandSelect" required>
    <% brands.forEach(b => { %>
      <option value="<%= b.BrandID %>"
        <%= b.BrandID == device.BrandID ? 'selected' : '' %>>
        <%= b.BrandName %>
      </option>
    <% }) %>
  </select>
</div>

<div class="form-group">
  <label>รุ่นอุปกรณ์</label>
  <select name="ModelID" id="modelSelect" required>
    <% models.forEach(m => { %>
      <option value="<%= m.ModelID %>"
        <%= m.ModelID == device.ModelID ? 'selected' : '' %>>
        <%= m.ModelName %>
      </option>
    <% }) %>
  </select>
</div>


  <div class="form-group">
    <label>หมวด</label>
    <select name="CategoryID" required>
      <% categories.forEach(c => { %>
        <option value="<%= c.CategoryID %>"
          <%= c.CategoryID == device.CategoryID ? 'selected' : '' %>>
          <%= c.CategoryName %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label>ประเภท</label>
    <select name="TypeID" required>
      <% types.forEach(t => { %>
        <option value="<%= t.TypeID %>"
          <%= t.TypeID == device.TypeID ? 'selected' : '' %>>
          <%= t.TypeName %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group full">
    <label>รายละเอียด</label>
    <textarea name="Description"><%= device.Description %></textarea>
  </div>

  <!-- Image -->
 <div class="form-group upload-box full">
  <label>รูปอุปกรณ์</label>

  <input
    type="file"
    name="DeviceImage"
    id="device_image"
    accept="image/*"
    hidden
  >

  <label for="device_image" class="upload-btn <%= device.DeviceImage ? 'active' : '' %>">

    <div class="upload-content">
      <i class="fa-solid fa-image"></i>
      <span>อัปโหลดรูปอุปกรณ์</span>
      <small>รองรับ jpg / png</small>
    </div>

    <% if (device.DeviceImage) { %>
      <img
        id="preview"
        src="/uploads/device/<%= device.DeviceImage %>"
      >
    <% } else { %>
      <img id="preview">
    <% } %>

  </label>
</div>


<div class="form-actions">
  <a href="/admin/device" class="btn-cancel">ยกเลิก</a>
  <button class="btn-save">บันทึกการแก้ไข</button>
</div>

</form>


</div>
