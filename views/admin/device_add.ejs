<link rel="stylesheet" href="/css/device_add.css">

<div class="top-bar">
  <h1>เพิ่มอุปกรณ์</h1>

  <div class="top-right">
    <div class="admin-box">
      <span>Admin</span>
      <i class="fa-solid fa-user"></i>
    </div>

    <div class="noti-wrap" id="notiWrap">
      <button class="noti-btn" id="notiBtn" aria-label="แจ้งเตือน">
        <i class="fa-solid fa-bell"></i>
        <span class="noti-badge" id="notiBadge" style="display:none;">0</span>
      </button>

      <div class="noti-dropdown" id="notiDropdown">
        <div class="noti-header">
          <span>การแจ้งเตือน</span>
          <span class="noti-count-label" id="notiCountLabel"></span>
        </div>
        <div class="noti-list" id="notiList">
          <div class="noti-empty">
            <i class="fa-solid fa-bell-slash"></i>
            <p>ไม่มีการแจ้งเตือน</p>
          </div>
        </div>
      </div>
    </div>
    <div class="logo-box">
      <img src="/images/logo.png">
    </div>
  </div>
</div>

<div class="admin-card">

  <div class="card-header">
    <i class="fa-solid fa-box"></i>
    <span>ข้อมูลอุปกรณ์</span>
  </div>

<form
  method="POST"
  action="/admin/device/add"
  enctype="multipart/form-data"
>

<div class="form-grid">

  <div class="form-group full">
    <label>ชื่ออุปกรณ์</label>
    <input
      name="DeviceName"
      placeholder="เช่น โน้ตบุ๊ก / โปรเจคเตอร์ / แท็บเล็ต"
      required
    >
  </div>

  <div class="form-group">
    <label>ยี่ห้อ</label>
    <select name="BrandID" id="brandSelect" required>
      <option value="">เลือกยี่ห้อ</option>
      <% brands.forEach(b => { %>
        <option value="<%= b.BrandID %>">
          <%= b.BrandName %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label>รุ่นอุปกรณ์</label>
    <select name="ModelID" id="modelSelect" required disabled>
      <option value="">เลือกรุ่น</option>
    </select>
  </div>


  <div class="form-group">
    <label>หมวด</label>
    <select name="CategoryID" required>
      <option value="">เลือกหมวด</option>
      <% categories.forEach(c => { %>
        <option value="<%= c.CategoryID %>">
          <%= c.CategoryName %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-group">
    <label>ประเภท</label>
    <select name="TypeID" required>
      <option value="">เลือกประเภท</option>
      <% types.forEach(t => { %>
        <option value="<%= t.TypeID %>">
          <%= t.TypeName %>
        </option>
      <% }) %>
    </select>
  </div>


  <div class="form-group full">
    <label>รายละเอียด</label>
    <textarea name="Description"></textarea>
  </div>

<div class="form-group upload-box full">
  <label>รูปอุปกรณ์</label>

  <input
    type="file"
    name="DeviceImage"
    id="device_image"
    accept="image/*"
    hidden
  >

<label for="device_image" id="uploadBtn" class="upload-btn">
  <span id="uploadText">📷 อัปโหลดรูป</span>
  <small id="uploadHint">รองรับ jpg / png (ไม่เกิน 2MB)</small>

  <img id="preview" class="preview-img">
</label>

  <img
    id="preview"
    class="preview-img"
    style="display:none; margin-top:10px; max-width:200px;"
  >
</div>

</div>

<div class="form-actions">
    <a href="/admin/device" class="btn-cancel">
      ยกเลิก
    </a>
  <button class="btn-save">บันทึก</button>
</div>

</form>
