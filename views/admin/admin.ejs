<div class="top-bar">

        <h1>ระบบการยืม-คืน</h1>

        <div class="top-right">
          
            <div class="admin-box">
                <span>Admin</span>
                <i class="fa-solid fa-user"></i>
            </div>

            <div class="noti-wrap" id="notiWrap">
              <button class="noti-btn" id="notiBtn" aria-label="แจ้งเตือน">
                <i class="fa-solid fa-bell"></i>
                <span class="noti-badge" id="notiBadge" style="display:none;">0</span>
              </button>

              <div class="noti-dropdown" id="notiDropdown">
                <div class="noti-header">
                  <span>การแจ้งเตือน</span>
                  <span class="noti-count-label" id="notiCountLabel"></span>
                </div>
                <div class="noti-list" id="notiList">
                  <div class="noti-empty">
                    <i class="fa-solid fa-bell-slash"></i>
                    <p>ไม่มีการแจ้งเตือน</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="logo-box">
                <img src="/images/logo.png">
            </div>
        </div>

    </div>

<!-- dashboard -->
<div class="dashboard">

  <div class="card card-blue">
    <h3>อุปกรณ์ทั้งหมด</h3>
    <img src="/images/icon2.png">
    <div class="num"><%= deviceTotal.total %></div>
  </div>

  <div class="card card-yellow">
    <h3>รอตรวจสอบ</h3>
    <img src="/images/icon1.png">
    <div class="num"><%= pending.total %></div>
  </div>

  <div class="card card-red">
    <h3>ไม่อนุมัติ</h3>
    <img src="/images/icon3.png">
    <div class="num"><%= rejected.total %></div>
  </div>

  <div class="card card-green">
    <h3>อนุมัติ</h3>
    <img src="/images/icon4.png">
    <div class="num"><%= approved.total %></div>
  </div>

  <div class="card card-purple">
    <h3>คืนแล้ว</h3>
    <img src="/images/icon5.png">
    <div class="num"><%= returned.total %></div>
  </div>

  <div class="card card-orange">
    <h3>เกินกำหนดคืน</h3>
    <img src="/images/icon6.png">
    <div class="num text-red"><%= overdue.total %></div>
  </div>

  <div class="card card-teal">
    <h3>ยอดอุปกรณ์คงเหลือ</h3>
    <img src="/images/icon7.png">
    <div class="num"><%= availableDevice.total %></div>
  </div>

  <div class="card card-gray">
    <h3>พนักงาน</h3>
    <img src="/images/icon8.png">
    <div class="num"><%= employeeTotal.total %></div>
  </div>

</div>

<!-- graph section -->
<div class="dashboard-graphs">

  <div class="graph-box">

  <div class="graph-title">
    <h3>สรุปสถานะการยืม</h3>
    <p class="graph-sub">ภาพรวมรายการยืม-คืนทั้งหมด</p>
  </div>

  <div class="graph-flex">

    <!-- chart -->
    <div class="chart-area">
      <canvas id="borrowChart"
        data-approved="<%= approved.total %>"
        data-pending="<%= pending.total %>"
        data-rejected="<%= rejected.total %>"
        data-returned="<%= returned.total %>"
        data-overdue="<%= overdue.total %>">
      </canvas>
    </div>

    <!-- legend custom -->
    <div class="legend-box">
      <div class="legend-item"><span class="dot green"></span> อนุมัติ <b><%= approved.total %></b></div>
      <div class="legend-item"><span class="dot yellow"></span> รอตรวจสอบ <b><%= pending.total %></b></div>
      <div class="legend-item"><span class="dot red"></span> ไม่อนุมัติ <b><%= rejected.total %></b></div>
      <div class="legend-item"><span class="dot blue"></span> คืนแล้ว <b><%= returned.total %></b></div>
      <div class="legend-item"><span class="dot purple"></span> เกินกำหนด <b><%= overdue.total %></b></div>
    </div>

  </div>

  <div class="graph-divider"></div>

    <div class="device-bars"
      data-available="<%= deviceStatus.available %>"
      data-borrowed="<%= deviceStatus.borrowed %>"
      data-repair="<%= deviceStatus.repair %>"
      data-total="<%= deviceTotal.total %>">

      <div class="bar-row">
        <span>คงเหลือ</span>
        <div class="bar"><div class="bar-fill" data-key="available"></div></div>
        <b><%= deviceStatus.available %></b>
      </div>

      <div class="bar-row">
        <span>ถูกยืม</span>
        <div class="bar"><div class="bar-fill" data-key="borrowed"></div></div>
        <b><%= deviceStatus.borrowed %></b>
      </div>

      <div class="bar-row">
        <span>ซ่อม</span>
        <div class="bar"><div class="bar-fill" data-key="repair"></div></div>
        <b><%= deviceStatus.repair %></b>
      </div>

    </div>

</div>

<div class="graph-box near-due-box">
  <h3>ใกล้ครบกำหนด / เกิน</h3>
  <p class="graph-sub">รายการที่ต้องติดตาม</p>

  <% if (nearDueList && nearDueList.length > 0) { %>

    <% nearDueList.forEach(item => { %>
      <div class="nitem">
        <div class="avatar"><%= item.fname[0] %><%= item.lname[0] %></div>
        <div class="ninfo">
          <div class="nname"><%= item.fname %> <%= item.lname %></div>
          <div class="ncode"><%= item.BorrowCode %></div>
        </div>
        <div class="ndays <%= item.remain_day < 0 ? 'over' : 'near' %>">
          <%= item.remain_day < 0 ? 'เกิน '+Math.abs(item.remain_day)+' วัน' : 'เหลือ '+item.remain_day+' วัน' %>
        </div>
      </div>
    <% }) %>

  <% } else { %>

    <div class="empty-state">
      <i class="fa-solid fa-circle-check"></i>
      <p>ไม่มีรายการใกล้ครบกำหนด</p>
      <span>ทุกการยืมอยู่ในระยะเวลาปกติ</span>
    </div>

  <% } %>

</div>

</div>
