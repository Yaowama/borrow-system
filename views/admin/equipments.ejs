  <h2>จัดการอุปกรณ์</h2>
        <a href="/admin/equipments/add" class="btn">
            + เพิ่มอุปกรณ์
        </a>

        <table class="table">
            <thead>
                <tr>
                    <th>รหัส</th>
                    <th>ชื่ออุปกรณ์</th>
                    <th>หมวด</th>
                    <th>ทั้งหมด</th>
                    <th>คงเหลือ</th>
                    <th>สถานะ</th>
                    <th>จัดการ</th>
                </tr>
            </thead>

            <tbody>
                <% equipments.forEach(eq => { %>
                    <tr>
                        <td><%= eq.EquipmentCode %></td>
                        <td><%= eq.EquipmentName %></td>
                        <td><%= eq.Category %></td>
                        <td><%= eq.QtyTotal %></td>
                        <td><%= eq.QtyAvailable %></td>
                        <td><%= eq.StatusID %></td>
                        <td>
                            <a href="/admin/equipments/edit/<%= eq.EquipmentID %>">✏️</a>
                            <a href="/admin/equipments/delete/<%= eq.EquipmentID %>"
                               onclick="return confirm('ลบอุปกรณ์นี้?')">
                               🗑️
                            </a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    </main>

</div>

