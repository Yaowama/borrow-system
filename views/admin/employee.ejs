<link rel="stylesheet" href="/css/employee.css">

<div class="top-bar">
  <h1>จัดการพนักงาน</h1>
  <div class="top-right">
    <div class="search">
      <input type="text" class="admin-search" placeholder="ค้นหาพนักงาน">
      <i class="fa-solid fa-magnifying-glass"></i>
    </div>
    <div class="admin-box">
      <span>Admin</span>
      <i class="fa-solid fa-user"></i>
    </div>
    <div class="noti-wrap" id="notiWrap">
      <button class="noti-btn" id="notiBtn" aria-label="แจ้งเตือน">
        <i class="fa-solid fa-bell"></i>
        <span class="noti-badge" id="notiBadge" style="display:none;">0</span>
      </button>
      <div class="noti-dropdown" id="notiDropdown">
        <div class="noti-header">
          <span>การแจ้งเตือน</span>
          <span class="noti-count-label" id="notiCountLabel"></span>
        </div>
        <div class="noti-list" id="notiList">
          <div class="noti-empty">
            <i class="fa-solid fa-bell-slash"></i>
            <p>ไม่มีการแจ้งเตือน</p>
          </div>
        </div>
      </div>
    </div>
    <div class="logo-box">
      <img src="/images/logo.png">
    </div>
  </div>
</div>

<!-- SUMMARY STRIP -->
<div class="emp-summary">
  <div class="emp-sum-item">
    <i class="fa-solid fa-users"></i>
    <div>
      <span class="sum-num"><%= employees.length %></span>
      <span class="sum-label">พนักงานทั้งหมด</span>
    </div>
  </div>
  <div class="emp-sum-item green">
    <i class="fa-solid fa-circle-check"></i>
    <div>
      <span class="sum-num"><%= employees.filter(e => e.IsActive == 1).length %></span>
      <span class="sum-label">ใช้งานอยู่</span>
    </div>
  </div>
  <div class="emp-sum-item red">
    <i class="fa-solid fa-circle-xmark"></i>
    <div>
      <span class="sum-num"><%= employees.filter(e => e.IsActive == 0).length %></span>
      <span class="sum-label">ปิดใช้งาน</span>
    </div>
  </div>
  <div class="emp-sum-item orange">
    <i class="fa-solid fa-triangle-exclamation"></i>
    <div>
      <span class="sum-num"><%= employees.filter(e => e.lateCount >= 3).length %></span>
      <span class="sum-label">มีประวัติเกินกำหนด</span>
    </div>
  </div>
</div>

<!-- TABLE -->
<div class="table-wrap">
  <table class="table" id="employeeTable">
    <thead>
      <tr>
        <th>#</th>
        <th>พนักงาน</th>
        <th>ติดต่อ</th>
        <th>สังกัด</th>
        <th>สิทธิ์</th>
        <th>พฤติกรรม</th>
        <th>สถานะ</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
    <% employees.forEach((e, index) => { %>
      <tr>
        <td class="col-no"><%= index + 1 %></td>

        <!-- พนักงาน -->
        <td>
          <div class="emp-cell">
            <div class="emp-avatar">
              <% if (e.ProfileImage) { %>
                <img src="/uploads/profile/<%= e.ProfileImage %>" alt="">
              <% } else { %>
                <span><%= e.fname[0] %><%= e.lname[0] %></span>
              <% } %>
            </div>
            <div>
              <div class="emp-name"><%= e.fname %> <%= e.lname %></div>
              <div class="emp-code">@<%= e.username %> · <%= e.EMP_NUM || e.EMPID %></div>
            </div>
          </div>
        </td>

        <!-- ติดต่อ -->
        <td>
          <div class="emp-contact">
            <span><i class="fa-solid fa-envelope"></i> <%= e.email %></span>
            <% if (e.fax) { %>
              <span><i class="fa-solid fa-fax"></i> <%= e.fax %></span>
            <% } %>
          </div>
        </td>

        <!-- สังกัด -->
        <td>
          <div class="emp-dept">
            <span class="dept-main"><%= e.InstitutionName || '-' %></span>
            <span class="dept-sub"><%= e.DepartmentName || '-' %></span>
          </div>
        </td>

        <!-- สิทธิ์ -->
        <td>
          <% if (e.RoleID == 2) { %>
            <span class="badge red"><i class="fa-solid fa-crown"></i> Admin</span>
          <% } else { %>
            <span class="badge blue"><i class="fa-solid fa-user"></i> User</span>
          <% } %>
        </td>

        <!-- พฤติกรรม -->
        <td>
          <% let late = e.lateCount || 0; let total = e.totalBorrow || 0; %>
          <div class="behavior-cell">
            <% if (late >= 5) { %>
              <span class="status-badge red"><i class="fa-solid fa-circle"></i> ระงับ</span>
            <% } else if (late >= 3) { %>
              <span class="status-badge yellow"><i class="fa-solid fa-circle"></i> เสี่ยง</span>
            <% } else { %>
              <span class="status-badge green"><i class="fa-solid fa-circle"></i> ปกติ</span>
            <% } %>
            <span class="borrow-count"><%= late %>/<%= total %> เกิน</span>
          </div>
        </td>

        <!-- สถานะ -->
        <td>
          <% if (e.IsActive == 1) { %>
            <span class="badge green"><i class="fa-solid fa-wifi"></i> ใช้งาน</span>
          <% } else { %>
            <span class="badge gray"><i class="fa-solid fa-ban"></i> ปิด</span>
          <% } %>
        </td>

        <!-- จัดการ -->
        <td>
          <button class="btn-action btn-view" data-id="<%= e.EMPID %>" title="ดูข้อมูล">
            <i class="fa-solid fa-pen-to-square"></i>
          </button>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<!-- EMPLOYEE EDIT MODAL -->
<div class="modal" id="employeeModal">
  <div class="modal-box employee-modal">
    <button class="close-btn" id="closeEmployeeModal">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <h2 class="modal-title">
      <i class="fa-solid fa-user-pen"></i> ข้อมูลพนักงาน
    </h2>

    <form id="employeeForm" enctype="multipart/form-data">

      <div class="profile-section">
        <div class="avatar-ring">
          <img id="profilePreview" class="profile-image">
          <label class="avatar-edit-btn" title="เปลี่ยนรูป">
            <i class="fa-solid fa-camera"></i>
            <input type="file" name="profileImage" id="profileImageInput" hidden>
          </label>
        </div>
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label>Username</label>
          <input type="text" name="username" disabled>
        </div>
        <div class="form-group">
          <label>วันที่สมัคร</label>
          <input type="text" name="CreateDate" disabled>
        </div>
        <div class="form-group">
          <label>ชื่อจริง</label>
          <input type="text" name="fname" required>
        </div>
        <div class="form-group">
          <label>นามสกุล</label>
          <input type="text" name="lname" required>
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required>
        </div>
        <div class="form-group">
          <label>รหัสพนักงาน</label>
          <input type="text" name="EMP_NUM" required>
        </div>
        <div class="form-group">
          <label>โทรศัพท์</label>
          <input type="text" name="phone">
        </div>
        <div class="form-group">
          <label>โทรสาร</label>
          <input type="text" name="fax">
        </div>
        <div class="form-group">
          <label>สำนัก</label>
          <select name="InstitutionID">
            <% institutions.forEach(ins => { %>
              <option value="<%= ins.InstitutionID %>"><%= ins.InstitutionName %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>ฝ่าย</label>
          <select name="DepartmentID">
            <% departments.forEach(dep => { %>
              <option value="<%= dep.DepartmentID %>"><%= dep.DepartmentName %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>สิทธิ์</label>
          <select name="RoleID">
            <option value="1">User</option>
            <option value="2">Admin</option>
          </select>
        </div>
        <div class="form-group">
          <label>สถานะ</label>
          <select name="IsActive">
            <option value="1">ใช้งาน</option>
            <option value="0">ปิดใช้งาน</option>
          </select>
        </div>
      </div>

      <div class="modal-actions">
        <button type="submit" class="btn-primary">
          <i class="fa-solid fa-floppy-disk"></i> บันทึกการเปลี่ยนแปลง
        </button>
      </div>

    </form>
  </div>
</div>