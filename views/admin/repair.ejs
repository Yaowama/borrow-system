<link rel="stylesheet" href="/css/repair.css">

<div class="top-bar">
  <h1>แจ้งซ่อมอุปกรณ์</h1>
  <div class="top-right">
    <div class="search">
      <input type="text" class="admin-search"
        data-target=".repair-row"
        placeholder="ค้นหาอุปกรณ์ / เลขใบซ่อม">
      <i class="fa-solid fa-magnifying-glass"></i>
    </div>
    <div class="admin-box">
      <span>Admin</span>
      <i class="fa-solid fa-user"></i>
    </div>
    
    <div class="logo-box"><img src="/images/logo.png"></div>
  </div>
</div>

<!-- SUMMARY -->
<div class="repair-summary">
  <div class="rs-item">
    <div class="rs-icon all"><i class="fa-solid fa-screwdriver-wrench"></i></div>
    <div>
      <div class="rs-num"><%= repairs.length %></div>
      <div class="rs-label">ทั้งหมด</div>
    </div>
  </div>
  <div class="rs-item">
    <div class="rs-icon wait"><i class="fa-solid fa-clock"></i></div>
    <div>
      <div class="rs-num"><%= repairs.filter(r => r.RepairStatusID === 1).length %></div>
      <div class="rs-label">รอรับงาน</div>
    </div>
  </div>
  <div class="rs-item">
    <div class="rs-icon working"><i class="fa-solid fa-gears"></i></div>
    <div>
      <div class="rs-num"><%= repairs.filter(r => r.RepairStatusID === 2).length %></div>
      <div class="rs-label">กำลังซ่อม</div>
    </div>
  </div>
  <div class="rs-item">
    <div class="rs-icon done"><i class="fa-solid fa-circle-check"></i></div>
    <div>
      <div class="rs-num"><%= repairs.filter(r => r.RepairStatusID === 3).length %></div>
      <div class="rs-label">ซ่อมเสร็จ</div>
    </div>
  </div>
  <div class="rs-item">
    <div class="rs-icon cancel"><i class="fa-solid fa-ban"></i></div>
    <div>
      <div class="rs-num"><%= repairs.filter(r => r.RepairStatusID === 4).length %></div>
      <div class="rs-label">ยกเลิก</div>
    </div>
  </div>
</div>

<!-- TABS -->
<div class="repair-tabs">
  <a href="/admin/repair?status=all" class="tab <%= status === 'all' ? 'active' : '' %>">
    <i class="fa-solid fa-list"></i> ทั้งหมด
  </a>
  <a href="/admin/repair?status=1" class="tab <%= status == '1' ? 'active' : '' %>">
    <i class="fa-solid fa-clock"></i> รอรับงาน
  </a>
  <a href="/admin/repair?status=2" class="tab <%= status == '2' ? 'active' : '' %>">
    <i class="fa-solid fa-gears"></i> กำลังซ่อม
  </a>
  <a href="/admin/repair?status=3" class="tab <%= status == '3' ? 'active' : '' %>">
    <i class="fa-solid fa-circle-check"></i> ซ่อมเสร็จ
  </a>
  <a href="/admin/repair?status=4" class="tab <%= status == '4' ? 'active' : '' %>">
    <i class="fa-solid fa-ban"></i> ยกเลิก
  </a>
</div>

<!-- TABLE -->
<div class="repair-table-wrap">
  <table class="table">
    <thead>
      <tr>
        <th>#</th>
        <th>รูป</th>  
        <th>อุปกรณ์</th>
        <th>เลขใบซ่อม</th>
        <th>ผู้แจ้ง</th>
        <th>วันที่แจ้ง</th>
        <th>ดำเนินการโดย</th>
        <th>สถานะ</th>
        <th>ดำเนินการ</th>   
        <th>เพิ่มเติม</th> 
      </tr>
    </thead>
    <tbody>
    <% if (repairs.length === 0) { %>
      <tr>
        <td colspan="10" class="empty-row">
          <i class="fa-solid fa-inbox"></i>
          <p>ไม่พบรายการแจ้งซ่อม</p>
        </td>
      </tr>
    <% } %>
    <% repairs.forEach((r, index) => { %>
    <tr class="repair-row">

      <td class="col-no"><%= index + 1 %></td>

      <!-- รูป -->
      <td class="td-img">
        <div class="device-thumb">
          <img src="/uploads/device/<%= r.DeviceImage %>"
              onerror="this.src='/images/no-image.png'">
        </div>
      </td>

      <!-- อุปกรณ์ -->
      <td>
        <div class="device-name"><%= r.DeviceName %></div>
        <div class="device-meta"><%= r.ITCode || '-' %> · <%= r.AssetTag || '-' %></div>
      </td>

      <!-- เลขใบซ่อม -->
      <td>
        <span class="repair-code"><%= r.RepairCode || '-' %></span>
      </td>

      <!-- ผู้แจ้ง -->
      <td>
        <div class="person-name"><%= r.CreateBy || '-' %></div>
      </td>

      <!-- วันที่ -->
      <td class="date-col"><%= r.CreateDate %></td>

      <!-- ช่าง -->
      <td>
        <% if (r.Technician) { %>
          <div class="tech-cell">
            <i class="fa-solid fa-user-gear"></i>
            <%= r.Technician %>
          </div>
        <% } else { %>
          <span class="no-data">—</span>
        <% } %>
      </td>

      <!-- สถานะ -->
      <td>
        <span class="badge status-<%= r.RepairStatusID %>">
          <%= r.RepairStatusName %>
        </span>
      </td>

      <!-- ดำเนินการ -->
      <td>
        <div class="action-group">
          <% if (r.RepairStatusID === 1) { %>
            <form action="/admin/repair/start/<%= r.RepairID %>" method="POST">
              <button class="btn blue">
                <i class="fa-solid fa-play"></i> รับงาน
              </button>
            </form>
          <% } else if (r.RepairStatusID === 2) { %>
            <form action="/admin/repair/process/<%= r.RepairID %>" method="POST">
              <button class="btn green">
                <i class="fa-solid fa-check"></i> ซ่อมเสร็จ
              </button>
            </form>
          <% } else if (r.RepairStatusID === 3) { %>
            <span class="done-label">
              <i class="fa-solid fa-circle-check"></i> เสร็จแล้ว
            </span>
          <% } else { %>
            <span class="no-data">—</span>
          <% } %>
        </div>
      </td>

      <!-- เพิ่มเติม -->
      <td>
        <div class="action-group">
          <button class="btn-detail" data-id="<%= r.RepairID %>" title="ดูรายละเอียด">
            <i class="fa-solid fa-eye"></i>
          </button>
          <% if (r.RepairStatusID !== 3 && r.RepairStatusID !== 4) { %>
            <button class="btn-repair-cancel" data-id="<%= r.RepairID %>" title="ยกเลิก">
              <i class="fa-solid fa-xmark"></i>
            </button>
          <% } %>
        </div>
      </td>

    </tr>
    <% }) %>
    </tbody>
  </table>
</div>

<!-- DETAIL MODAL -->
<div class="modal" id="repairDetailModal">
  <div class="repair-detail-modal">
    <button id="closeDetail" class="close-btn">
      <i class="fa-solid fa-xmark"></i>
    </button>
    <div class="repair-modal-header">
      <i class="fa-solid fa-screwdriver-wrench"></i>
      <h2>รายละเอียดใบซ่อม</h2>
    </div>
    <div class="modal-body" id="detailContent"></div>
  </div>
</div>

<!-- CANCEL CONFIRM MODAL -->
<div id="deleteModal" class="delete-modal">
  <div class="modal-box">
    <div class="check-wrapper">
      <svg class="warningmark" viewBox="0 0 52 52">
        <circle class="warning-circle" cx="26" cy="26" r="23" fill="none"/>
        <line class="warning-line" x1="26" y1="14" x2="26" y2="30"/>
        <circle class="warning-dot" cx="26" cy="36" r="2"/>
      </svg>
    </div>
    <h3>ยืนยันการยกเลิก</h3>
    <p>คุณต้องการยกเลิกคำสั่งซ่อมนี้ใช่หรือไม่?</p>
    <div class="modal-actions">
      <button class="btn-cancel">กลับ</button>
      <button id="confirmDeleteBtn" class="btn-danger">ยืนยัน</button>
    </div>
  </div>
</div>