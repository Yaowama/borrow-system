<link rel="stylesheet" href="/css/repair.css">

<div class="top-bar">

        <h1>แจ้งซ่อมอุปกรณ์</h1>

        <div class="top-right">
          <div class="search">
              <input
                type="text"
                class="admin-search"
                data-target=".repair-row"
                placeholder="ค้นหาอุปกรณ์ / เลขใบซ่อม"
              >
              <i class="fa-solid fa-magnifying-glass"></i>
          </div>
            <div class="admin-box">
                <span>Admin</span>
                <i class="fa-solid fa-user"></i>
            </div>
 
            <div class="logo-box">
                <img src="/images/logo.png">
            </div>
        </div>
    </div>

    <div class="repair-tabs">
      <a href="/admin/repair?status=all"
        class="tab <%= status === 'all' ? 'active' : '' %>">
        ทั้งหมด
      </a>
      <a href="/admin/repair?status=1" class="tab <%= status == '1' ? 'active' : '' %>">
        รอรับงาน
      </a>

      <a href="/admin/repair?status=2" class="tab <%= status == '2' ? 'active' : '' %>">
        กำลังซ่อม
      </a>

      <a href="/admin/repair?status=3" class="tab <%= status == '3' ? 'active' : '' %>">
        ซ่อมเสร็จ
      </a>

      <a href="/admin/repair?status=4" class="tab <%= status == '4' ? 'active' : '' %>">
        ยกเลิก
      </a>

     
    </div>

<table class="table">
  <thead>
    <tr>
    <th>No.</th>
    <th>รูป</th>
    <th>เลขใบซ่อม</th>
    <th>อุปกรณ์</th>
    <th>ผู้แจ้ง</th>
    <th>วันที่ส่งซ่อม</th>
    <th>สถานะ</th>
    <th>ดำเนินการโดย</th>
    <th>จัดการ</th>
    <th></th>
  </tr>
  </thead>

  <tbody>
  <% repairs.forEach((r, index) => { %>
  <tr class="repair-row">

    <td><%= index + 1 %></td>

    <td>
      <img src="/uploads/device/<%= r.DeviceImage %>" class="table-img">
    </td>

    <td><%= r.RepairCode || '-' %></td>

    <td>
      <strong><%= r.DeviceName %></strong><br>
      <small><%= r.AssetCode %></small>
    </td>

    <td><%= r.CreateBy || '-' %></td>

    <td><%= r.CreateDate %></td>

    <td>
      <span class="badge status-<%= r.RepairStatusID %>">
        <%= r.RepairStatusName %>
      </span>
    </td>

    <td><%= r.Technician || '-' %></td>

    <td>

  <% if (!r.RepairStatusID || r.RepairStatusID === 0) { %>

    <span>-</span>

  <% } else if (r.RepairStatusID === 1) { %>

    <form action="/admin/repair/start/<%= r.RepairID %>" method="POST">
      <button class="btn blue">รับงาน</button>
    </form>

  <% } else if (r.RepairStatusID === 2) { %>

    <form action="/admin/repair/process/<%= r.RepairID %>" method="POST">
      <button class="btn green">ซ่อมเสร็จ</button>
    </form>

  <% } else if (r.RepairStatusID === 3) { %>

    <span class="done">เสร็จแล้ว</span>

  <% } else { %>

    <span>-</span>

  <% } %>

</td>

    <td>
  <button class="btn-detail" data-id="<%= r.RepairID %>">
    <i class="fa-solid fa-eye"></i>
  </button>

  <% if (r.RepairStatusID !== 3 && r.RepairStatusID !== 4) { %>
   <button
      type="button"
      class="btn-repair-cancel"
      data-id="<%= r.RepairID %>"
      title="ยกเลิกคำสั่งซ่อม"
    >
      <i class="fa-solid fa-xmark"></i>
    </button>
  <% } %>
</td>

  </tr>
<% }) %>
</tbody>
</table>

<div class="modal" id="repairDetailModal">
  <div class="modal-box-detail-modal">
    <button id="closeDetail" class="close-btn"> <i class="fa-solid fa-xmark"></i></button>
    <div class="modal-body" id="detailContent"></div>
  </div>
</div>

<!-- ✅ DELETE MODAL ต้องอยู่นอก if -->
<div id="deleteModal" class="delete-modal">
  <div class="modal-box">

    <div class="check-wrapper danger">
      <svg class="warningmark" viewBox="0 0 52 52">
        <circle class="warning-circle" cx="26" cy="26" r="23" fill="none"/>
        <line class="warning-line" x1="26" y1="14" x2="26" y2="30"/>
        <circle class="warning-dot" cx="26" cy="36" r="2"/>
      </svg>
    </div>

    <h3>ยืนยันการยกเลิก</h3>
    <p>คุณต้องการยกเลิกคำสั่งซ่อมนี้ใช่หรือไม่ ?</p>

    <div class="modal-actions">
      <button class="btn-cancel">กลับ</button>
      <button id="confirmDeleteBtn" class="btn-danger">ยืนยัน</button>
    </div>
  </div>
</div>



