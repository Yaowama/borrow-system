<!-- ================= TOP BAR ================= -->
<div class="top-bar">
    <h1>ระบบการยืม-คืน</h1>

    <!-- ขวา -->
    <div class="top-right">

          <div class="search">
              <input
                type="text"
                class="admin-search"
                data-target=".borrow_list-row"
                placeholder="ค้นหาอุปกรณ์"
                >
              <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          
           <div class="logo-box">
                <img src="/images/logo.png">
            </div>

      </div>

</div>
<div class="welcome-box">
  <div class="user-info">
    <img src="/uploads/profile/<%= user.ProfileImage || 'default.png' %>" class="avatar">
    <div>
<h3>
  สวัสดี <%= user.fname %> <%= user.lname %>
</h3>
      <p>ยินดีต้อนรับสู่ระบบยืม–คืน</p>
    </div>
  </div>
</div>

<div class="summary-cards">

  <div class="sum-card blue">
    <i class="fa-solid fa-box"></i>
    <span>กำลังยืม: <%= stats.borrowing || 0 %></span>
  </div>

  <div class="sum-card yellow">
    <i class="fa-solid fa-clock"></i>
    <span>รออนุมัติ: <%= stats.pending || 0 %></span>
  </div>

  <div class="sum-card green">
    <i class="fa-solid fa-check"></i>
    <span>เกินกำหนด: <%= stats.overdue || 0 %></span>
  </div>

  <div class="sum-card gray">
    <i class="fa-solid fa-folder"></i>
    <span>ประวัติ: <%= stats.history || 0 %></span>
  </div>

</div>
<!-- ================= DEVICE GRID ================= -->
<div class="device-grid">

  <% types.forEach(t => { %>
    <div class="device-card" data-type="<%= t.TypeID %>">

      <!-- image -->
      <div class="device-img-box">
        <% if (t.TypeImage) { %>
          <img src="/uploads/type/<%= t.TypeImage %>">
          <% } else { %>
          <div class="no-img">No Image</div>
        <% } %>
      </div>

      <!-- info -->
      <div class="device-info">
        <h3><%= t.TypeName %></h3>

        <p class="category">
          <%= t.CategoryName || "-" %>
        </p>
      </div>

      <!-- footer -->
      <div class="device-footer">

        <span class="stock 
          <%= t.Stock > 3 ? 'green' : t.Stock > 0 ? 'yellow' : 'red' %>">
          <%= t.Stock > 0 ? `เหลือ ${t.Stock} เครื่อง` : 'หมด' %>
        </span>

        <% if (t.Stock > 0) { %>
          <button class="btn blue borrowBtn"
                  data-id="<%= t.TypeID %>"
                  data-name="<%= t.TypeName %>"
                  data-stock="<%= t.Stock %>">
            ยืม
          </button>
        <% } else { %>
          <span class="btn gray disabled">หมด</span>
        <% } %>

      </div>

    </div>
  <% }) %>

</div>


<!-- Modal ยืมอุปกรณ์ -->
<div id="borrowModal" class="modal">
  <div class="modal-content">
    <span class="close">&times;</span>
    <h2>ยืมอุปกรณ์</h2>

    <div class="device-summary">
      <p>อุปกรณ์: <span id="modalDeviceName"></span></p>
      <p>จำนวนคงเหลือ: <span id="modalRemainQty"></span> ชิ้น</p>
    </div>

    <form id="borrowForm">
      <input type="hidden" name="DeviceID" id="modalDeviceID">

      <div class="form-group">
        <label>จำนวนที่ต้องการยืม</label>
        <input type="number" name="qty" id="modalQty" min="1" value="1" required>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>วันที่ยืม</label>
          <input type="date" name="BorrowDate" id="modalBorrowDate"
            value="<%= new Date().toISOString().split('T')[0] %>"
            min="<%= new Date().toISOString().split('T')[0] %>" required>
        </div>

        <div class="form-group">
          <label>วันที่คืน</label>
          <input type="date" name="DueDate" id="modalDueDate"
            value="<%= new Date(Date.now()+86400000).toISOString().split('T')[0] %>" required>
        </div>
      </div>

      <div class="form-group">
        <label>วัตถุประสงค์ในการยืม</label>
        <textarea name="purpose" rows="3" required></textarea>
      </div>

      <div class="form-group">
        <label>สถานที่ใช้งาน</label>
        <input type="text" name="location" required>
      </div>

      <div class="form-group">
        <label>หมายเหตุ</label>
        <textarea name="note" rows="2"></textarea>
      </div>

      <button type="submit" class="btn-confirm">ยืนยันการยืม</button>
    </form>
  </div>
</div>

