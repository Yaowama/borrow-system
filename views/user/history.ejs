<link rel="stylesheet" href="/css/borrow_status.css">

<main class="main">

<div class="top-bar">
  <div class="top-left">
    <h1>ประวัติการยืม</h1>
  </div>

  <div class="top-right">
    <div class="logo-box">
      <img src="/images/logo.png">
    </div>
  </div>
</div>

<table class="status-table">
  <thead>
    <tr>
      <th>รูป</th>
      <th>อุปกรณ์</th>
      <th>รหัส</th>
      <th>วันที่ยืม</th>
      <th>กำหนดคืน</th>
      <th>วันที่คืน</th>
      <th>สถานะ</th>
      <th>รายละเอียด</th>
    </tr>
  </thead>

  <tbody>
    <% rows.forEach(r => { %>
      <tr>

        <td>
          <div class="device-image">
            <img src="/uploads/device/<%= r.DeviceImage %>"
                 onerror="this.src='/images/no-image.png'">
          </div>
        </td>

        <td>
          <div class="device-info">
            <strong><%= r.DeviceName %></strong>
            <div class="meta">
              <%= r.BrandName || "-" %> · <%= r.ModelName || "-" %>
            </div>
          </div>
        </td>

        <td><%= r.BorrowCode %></td>
        <td><%= r.BorrowDate %></td>
        <td><%= r.DueDate %></td>

        <td>
          <%= r.ReturnDate || "-" %>
        </td>

        <td>
          <span class="status status-<%= r.BorrowStatusID %>">
            <%= r.StatusName %>
          </span>
        </td>

        <td>
          <button
            class="icon-action view btn-detail"
            data-code="<%= r.BorrowCode %>"
            title="ดูรายละเอียด">
            <i class="fa-solid fa-eye"></i>
          </button>
        </td>

      </tr>
    <% }) %>
  </tbody>
</table>

<% if (rows.length === 0) { %>
    <div class="empty-box">
      <i class="fa-solid fa-box-open"></i>
      <p>ขณะนี้คุณไม่มีอุปกรณ์ที่กำลังยืม</p>
    </div>
  <% } else { %>

<!-- DETAIL MODAL -->
<div class="overlay" id="detailOverlay">
  <div class="detail-modal">
    <div class="modal-header">
      <h2>รายละเอียดการยืม</h2>
      <span class="close-modal" id="closeDetail">&times;</span>
    </div>
    <div class="modal-body" id="detailContent"></div>
  </div>
</div>

</main>

<% } %>