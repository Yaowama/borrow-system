<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">

    <title>
        <%= title || "User Dashboard" %>
    </title>

    <link rel="stylesheet" href="/css/user.css">
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body data-role="user" data-success="<%= typeof success !== 'undefined' ? success : '' %>">

<div class="container">

    <%- include("./sidebar", { user, active: active || "" }) %>

    <main class="content">
        <div class="content-scroll">
            <%- include(page) %>
        </div>
    </main>

</div>

<!-- Success Modal -->
<div id="successModal" class="success-modal">
  <div class="modal-box">
    <div class="check-wrapper">
      <svg class="checkmark" viewBox="0 0 52 52">
        <circle class="checkmark-circle" cx="26" cy="26" r="23" fill="none"/>
        <path class="checkmark-check" fill="none"
              d="M14 27 l7 7 l17 -17"/>
      </svg>
    </div>
    <h2></h2>
    <p></p>
  </div>
</div>

<!-- BARCODE OVERLAY -->
<div id="barcodeOverlay" class="barcode-overlay">
  <img id="barcodePreview" />
</div>


<% if (show2faWarning) { %>
<div class="banner-2fa" id="b2fa">
  <div class="banner-top">
    <span class="bi">🔐</span>
    <div class="banner-top-txt">
      <h4>เพิ่มความปลอดภัยด้วย 2FA</h4>
      <p>ป้องกันบัญชีจากการเข้าถึงโดยไม่รับอนุญาต</p>
    </div>
  </div>
  <div class="banner-body">
    <p>เปิดใช้งาน Two-Factor Authentication เพื่อเพิ่มชั้นความปลอดภัย ระบบจะส่ง OTP ทาง Email ทุกครั้งที่เข้าสู่ระบบ</p>
    <div class="banner-actions">
      <button class="banner-btn-yes" id="btnGoProfile">ตั้งค่าเลย</button>
      <button class="banner-btn-no" id="btnDismiss2FA">ไม่สนใจ 10 วัน</button>
    </div>
  </div>
</div>
<% } %>


<script src="/js/borrow_status.js"></script>
<script src="/js/user.js"></script>
<script src="/js/profile.js"></script>
<script src="/js/change_password.js"></script>

</body>
</html>
